# Backend origin, e.g. http://localhost:5004 — OR http://localhost:5004/api/v1 (not both doubled).
# Production: must point at the API host so <img> URLs use …/uploads/… on the server that stores files.
# If the SPA is same-origin with the API, your reverse proxy must forward both /api and /uploads to Node.
#
# Local dev: you can keep VITE_BASE_URL=http://localhost:5004 — the app rewrites to same-origin
# /api/v1 so Vite’s proxy (see vite.config.ts) is used and deal API calls avoid CORS failures.
# Set VITE_FORCE_ABSOLUTE_API_URL=true only if you intentionally need cross-origin requests to localhost.
VITE_BASE_URL=
# VITE_DEV_API_PROXY=http://127.0.0.1:5004
# VITE_FORCE_ABSOLUTE_API_URL=

API_VERSION=

PORT=

# Optional: Dropbox Sign client id for embedded iframe (must match backend DROPBOX_SIGN_CLIENT_ID).
# API key must only live in backend/.env — never put DROPBOX_SIGN_API_KEY in the frontend.
# VITE_DROPBOX_SIGN_CLIENT_ID=
